        warn(" ไม่เจอ ProximityPrompt → hop")
        hop()
        return
    end

    local backpack = player:FindFirstChild("Backpack")
    local countBefore = backpack and #backpack:GetChildren() or 0

    fireproximityprompt(prompt)

    task.wait(CONFIG.afterBuyDelay)

    local countAfter = backpack and #backpack:GetChildren() or 0

    if countAfter > countBefore then
        local newPet = ""
        for _, tool in ipairs(backpack:GetChildren()) do
            for name in pairs(targetPets) do
                if tool.Name:find(name) then
                    newPet = tool.Name
                end
            end
        end

        print(" ซื้อสำเร็จจริง:", newPet)

        sendWebhook(
            " ซื้อ Pet สำเร็จ!",
            "**Pet:** `" .. newPet .. "`\n" ..
            "**ผู้เล่น:** `" .. player.Name .. "`\n" ..
            "**Server:** `" .. game.JobId .. "`\n\n" ..
            " **สถิติ**\n" ..
            "ซื้อแล้ว: `" .. buyCount .. "` ครั้ง\n" ..
            "Hop แล้ว: `" .. hopCount .. "` ครั้ง",
            3066993
        )
    else
        warn(" ซื้อไม่ติด → hop")
    end

    print(" hop หา server ใหม่...")
    hop()
end


