local function getFolder()
    local map = workspace:FindFirstChild("Map")
    if not map then return nil end
    return map:FindFirstChild("WildPetSpawns")
end



local function findPet()
    local folder = getFolder()
    if not folder then return nil end

    local sizeScore = {
        Huge   = 3,
        Big    = 2,
        Normal = 1,
    }

    local bestPet   = nil
    local bestScore = 0

    for _, pet in ipairs(folder:GetDescendants()) do
        local petName = pet.Name

        local matchConfig = nil
        for species, config in pairs(targetPets) do
            if petName:find(species) then
                matchConfig = config
                break
            end
        end

        if not matchConfig then continue end

        local isHuge    = petName:find("Huge") ~= nil
        local isBig     = petName:find("Big") ~= nil and not isHuge
        local isNormal  = not isHuge and not isBig
        local isRainbow = petName:find("Rainbow") ~= nil

        local sizeOk = false
        if isHuge   and matchConfig.Huge   then sizeOk = true end
        if isBig    and matchConfig.Big    then sizeOk = true end
        if isNormal and matchConfig.Normal then sizeOk = true end

        local typeOk = false
        if isRainbow     and matchConfig.Rainbow then typeOk = true end
        if not isRainbow and matchConfig.Normal  then typeOk = true end

        if not sizeOk or not typeOk then continue end

        local size  = isHuge and "Huge" or isBig and "Big" or "Normal"
        local score = sizeScore[size]
        if isRainbow then score = score + 10 end

        if score > bestScore then
            bestScore = score
            bestPet   = pet
        end
    end

    return bestPet
end



local function moveTo(pet)
    local part = pet:FindFirstChildWhichIsA("BasePart", true)
    if not part then
        warn("ไม่เจอ BasePart")
        return false
    end

    local partPos = part.Position
    if not partPos then return false end

    local startPos  = rootPart.Position
    local targetPos = partPos + Vector3.new(0, 3, 0)
    local distance  = (targetPos - startPos).Magnitude

    if not distance or distance == 0 then return true end

    local direction = (targetPos - startPos).Unit
    if direction ~= direction then return true end

    local stepSize  = 3
    local stepDelay = 0.09
    local maxSteps  = 500
    local stepCount = 0

    for i = 0, distance, stepSize do
        if not pet or not pet.Parent then
            warn("pet หายระหว่างเดิน")
            return false
        end

        stepCount += 1
        if stepCount > maxSteps then
            warn("เกิน maxSteps")
            break
        end

        rootPart.CFrame = CFrame.new(startPos + direction * i)
        task.wait(stepDelay)
    end

    rootPart.CFrame = CFrame.new(targetPos)
    return true
end



local function getServers(cursor)
    local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"
    if cursor then url = url .. "&cursor=" .. cursor end

    local success, response = pcall(function() return game:HttpGet(url) end)
    if not success or not response then return nil end

    local ok, data = pcall(function() return HttpService:JSONDecode(response) end)
    if not ok or not data or not data.data then return nil end

    return data
end

local function collectServers()
    local list, cursor = {}, nil

    for _ = 1, CONFIG.maxHopPages do
        local data = getServers(cursor)
        if not data then break end

        for _, v in ipairs(data.data) do
            local isPublic = v.serverType == nil or v.serverType == "Public"

            if v.id ~= game.JobId
                and v.playing < v.maxPlayers
                and isPublic
            then
                table.insert(list, v.id)
            end
        end

        cursor = data.nextPageCursor
        if not cursor then break end
    end

    return list
end



local function hop()
    print("ไม่เจอ → hop server")
    hopCount += 1

    local servers = collectServers()

    if not servers or type(servers) ~= "table" or #servers == 0 then
        warn("fallback teleport")
        TeleportService:Teleport(placeId, player)
        return
    end

    local available = {}
    for _, id in ipairs(servers) do
        if id and not usedServers[id] then
            table.insert(available, id)
        end
    end

    if #available == 0 then
        warn("ล้าง blacklist")
        usedServers = {}
        available = servers
    end

    if #available == 0 then
        TeleportService:Teleport(placeId, player)
        return
    end

    for attempt = 1, CONFIG.maxHopTry do
        if #available == 0 then break end

        local target = available[math.random(1, #available)]
        if not target then break end

        for i, id in ipairs(available) do
            if id == target then
                table.remove(available, i)
                break
            end
        end

        usedServers[target] = true
        print("Hop ครั้งที่", attempt, "→", target)

        local done      = false
        local hopSuccess = false

        task.spawn(function()
            local ok, err = pcall(function()
                TeleportService:TeleportToPlaceInstance(placeId, target, player)
            end)

            if not ok then
                warn("Hop error:", err)
                if err and (err:find("773") or err:find("restricted")) then
                    warn("773 restricted → blacklist แล้วลองใหม่")
                    usedServers[target] = true
                else
                    pcall(function()
                        TeleportService:Teleport(placeId, player)
                    end)
                    hopSuccess = true
                end
            else
                hopSuccess = true
            end

            done = true
        end)

        local elapsed = 0
        while not done and elapsed < CONFIG.hopTimeout do
            task.wait(0.1)
            elapsed += 0.1
        end

        if hopSuccess then
            print("Hop สำเร็จ | รวม:", hopCount, "ครั้ง")
            return
        end

        if not done then
            warn("Hop timeout ครั้งที่", attempt, "→ ลองใหม่")
        end

        task.wait(0.3)
    end

    warn("ลองหมดแล้ว → fallback")
    TeleportService:Teleport(placeId, player)
end



local function hasPetTool(petName)
    local backpack = player:FindFirstChild("Backpack")
    if not backpack then return false end

    for _, tool in ipairs(backpack:GetChildren()) do
        if tool:IsA("Tool") and tool.Name:find(petName) then
            return true
        end
    end

    return false
end

local function waitForPetTool(petName, timeout)
    local startTime = tick()

    repeat
        if hasPetTool(petName) then return true end
        task.wait(0.5)
    until tick() - startTime >= timeout

    return false
end



