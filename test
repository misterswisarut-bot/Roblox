local function sendWebhook(title, description, color)
    if not CONFIG.webhookUrl or CONFIG.webhookUrl == "" then return end

    -- นับ pet ในกระเป๋าทั้งหมด
    local backpack = player:FindFirstChild("Backpack")
    local petCount = {}

    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then
                petCount[tool.Name] = (petCount[tool.Name] or 0) + 1
            end
        end
    end

    -- สร้างข้อความกระเป๋า
    local bagText = ""
    if next(petCount) then
        for name, count in pairs(petCount) do
            bagText = bagText .. "• `" .. name .. "` x" .. count .. "\n"
        end
    else
        bagText = "ว่างเปล่า"
    end

    local data = HttpService:JSONEncode({
        embeds = {{
            title       = title,
            description = description .. "\n\n🎒 **กระเป๋าตอนนี้:**\n" .. bagText,
            color       = color or 3066993,
            footer      = { text = "🐾Pet Grow a Garden" },
        }}
    })

    pcall(function()
        if syn and syn.request then
            syn.request({
                Url     = CONFIG.webhookUrl,
                Method  = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body    = data
            })
        elseif request then
            request({
                Url     = CONFIG.webhookUrl,
                Method  = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body    = data
            })
        elseif http and http.request then
            http.request({
                Url     = CONFIG.webhookUrl,
                Method  = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body    = data
            })
        end
    end)
end



local function autoSkipLoadingScreen()
    print("รอหน้า loading...")
    local deadline = tick() + CONFIG.skipTimeout

    while tick() < deadline do
        for _, gui in ipairs(playerGui:GetChildren()) do
            if not gui:IsA("ScreenGui") then continue end
            for _, obj in ipairs(gui:GetDescendants()) do
                if not obj:IsA("GuiObject") then continue end
                if not obj.Visible then continue end

                local text = ""
                if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                    text = obj.Text:lower()
                end

                if text:find("click to skip") or text:find("loading player data") then
                    print("เจอหน้า loading:", obj.Text)

                    local center = workspace.CurrentCamera.ViewportSize / 2
                    pcall(function()
                        VIM:SendMouseButtonEvent(center.X, center.Y, 0, true, game, 0)
                        task.wait(0.05)
                        VIM:SendMouseButtonEvent(center.X, center.Y, 0, false, game, 0)
                    end)

                    local t = tick()
                    repeat task.wait(0.5)
                    until not obj.Visible or not obj.Parent or tick() - t > 10

                    print("Loading หายแล้ว → รอ", CONFIG.afterSkipDelay, "วิ")
                    task.wait(CONFIG.afterSkipDelay)
                    return true
                end
            end
        end
        task.wait(0.5)
    end

    warn("ไม่เจอ loading → ข้ามไปเลย")
    return false
end

autoSkipLoadingScreen()



local targetPets = {
    Unicorn   = true,
    Raccoon   = true,
    GoldenDragonfly = true,
    Bunny = true,
}



local function getFolder()
    local map = workspace:FindFirstChild("Map")
    if not map then return nil end
    return map:FindFirstChild("WildPetSpawns")
end



local function findPet()
    local folder = getFolder()
    if not folder then return nil end

    for _, pet in ipairs(folder:GetDescendants()) do
        for name in pairs(targetPets) do
            if pet.Name:find(name) then
                return pet
            end
        end
    end

    return nil
end



local function moveTo(pet)
    local part = pet:FindFirstChildWhichIsA("BasePart", true)
    if not part then
        warn("ไม่เจอ BasePart")
        return false
    end

    local partPos = part.Position
    if not partPos then return false end

    local startPos  = rootPart.Position
    local targetPos = partPos + Vector3.new(0, 3, 0)
    local distance  = (targetPos - startPos).Magnitude

    if not distance or distance == 0 then return true end

    local direction = (targetPos - startPos).Unit
    if direction ~= direction then return true end

    local stepSize  = 3
    local stepDelay = 0.09
    local maxSteps  = 500
    local stepCount = 0

    for i = 0, distance, stepSize do
        if not pet or not pet.Parent then
            warn("pet หายระหว่างเดิน")
            return false
        end

        stepCount += 1
        if stepCount > maxSteps then
            warn("เกิน maxSteps")
            break
        end

        rootPart.CFrame = CFrame.new(startPos + direction * i)
        task.wait(stepDelay)
    end

    rootPart.CFrame = CFrame.new(targetPos)
    return true
end



local function getServers(cursor)
    local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"
    if cursor then url = url .. "&cursor=" .. cursor end

    local success, response = pcall(function() return game:HttpGet(url) end)
    if not success or not response then return nil end

    local ok, data = pcall(function() return HttpService:JSONDecode(response) end)
    if not ok or not data or not data.data then return nil end

    return data
end

local function collectServers()
    local list, cursor = {}, nil

    for _ = 1, CONFIG.maxHopPages do
        local data = getServers(cursor)
        if not data then break end

        for _, v in ipairs(data.data) do
            if v.id ~= game.JobId and v.playing < v.maxPlayers then
                table.insert(list, v.id)
            end
        end

        cursor = data.nextPageCursor
        if not cursor then break end
    end

    return list
end



local function hop()
    print("ไม่เจอ → hop server")
    hopCount += 1

    local servers = collectServers()

    if not servers or type(servers) ~= "table" or #servers == 0 then
        warn("fallback teleport")
        TeleportService:Teleport(placeId, player)
        return
    end

    local available = {}
    for _, id in ipairs(servers) do
        if id and not usedServers[id] then
            table.insert(available, id)
        end
    end

    if #available == 0 then
        warn("ล้าง blacklist")
        usedServers = {}
        available = servers
    end

    if #available == 0 then
        TeleportService:Teleport(placeId, player)
        return
    end

    for attempt = 1, CONFIG.maxHopTry do
        if #available == 0 then break end

        local target = available[math.random(1, #available)]
        if not target then break end

        for i, id in ipairs(available) do
            if id == target then
                table.remove(available, i)
                break
            end
        end

        usedServers[target] = true
        print("Hop ครั้งที่", attempt, "→", target)

        local done = false
        local hopSuccess = false

        task.spawn(function()
            local ok, err = pcall(function()
                TeleportService:TeleportToPlaceInstance(placeId, target, player)
            end)

            if not ok then
                warn("Hop error:", err)
                if err and (err:find("773") or err:find("restricted")) then
                    warn("773 → fallback Teleport")
                    pcall(function()
                        TeleportService:Teleport(placeId, player)
                    end)
                    hopSuccess = true
                end
            else
                hopSuccess = true
            end

            done = true
        end)

        local elapsed = 0
        while not done and elapsed < CONFIG.hopTimeout do
            task.wait(0.1)
            elapsed += 0.1
        end

        if hopSuccess then
            print("Hop สำเร็จ | รวม:", hopCount, "ครั้ง")
            return
        end

        if not done then
            warn("Hop timeout ครั้งที่", attempt, "→ ลองใหม่")
        end

        task.wait(0.3)
    end

    warn("ลองหมดแล้ว → fallback")
    TeleportService:Teleport(placeId, player)
end



local function hasPetTool(petName)
    local backpack = player:FindFirstChild("Backpack")
    if not backpack then return false end

    for _, tool in ipairs(backpack:GetChildren()) do
        if tool:IsA("Tool") and tool.Name:find(petName) then
            return true
        end
    end

    return false
end

local function waitForPetTool(petName, timeout)
    local startTime = tick()

    repeat
        if hasPetTool(petName) then return true end
        task.wait(0.5)
    until tick() - startTime >= timeout

    return false
end



